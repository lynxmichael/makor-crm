// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Utilisateurs internes & Authentification ---
model User {
  id                  String   @id @default(cuid())

  // Informations
  email               String   @unique
  passwordHash        String

  firstName           String
  lastName            String
  phone               String?
  avatar              String?

  isActive            Boolean  @default(true)
  isVerified          Boolean  @default(false)

  twoFactorEnabled    Boolean  @default(false)
  twoFactorSecret     String?

  lastLoginAt         DateTime?
  lastPasswordChange  DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  roles               UserRole[]

  sessions            UserSession[]

  refreshTokens       RefreshToken[]

  loginHistory        LoginHistory[]

  passwordResets      PasswordReset[]

  emailVerifications  EmailVerification[]

  auditLogs           AuditLog[]

  notifications       Notification[]

  apiKeys             ApiKey[]

  assignedTickets     Ticket[] @relation("AgentTickets")

  createdClients      Customer[] @relation("CreatedBy")

  interactions        Interaction[]

  interventions       Intervention[]
}
model Role {

  id          String   @id @default(cuid())

  name        String   @unique

  code        String   @unique

  description String?

  isSystem    Boolean  @default(false)

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  users       UserRole[]

  permissions RolePermission[]
}
model Permission {

  id          String   @id @default(cuid())

  name        String

  code        String   @unique

  module      String

  description String?

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  roles       RolePermission[]
}

model UserRole {

  id        String @id @default(cuid())

  userId    String

  roleId    String

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, roleId])
}
model RolePermission {

  id            String @id @default(cuid())

  roleId        String

  permissionId  String

  role          Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// --- Clients & Prospects ---
model Customer {
  id          String       @id @default(cuid())
  type        CustomerType
  firstName   String
  lastName    String
  companyName String?
  email       String?      @unique
  phone       String?
  address     String?
  city        String?
  country     String?
  gdprConsent Boolean      @default(false)
  createdById String?
  createdBy   User?        @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  subscriptions      Subscription[]
  tickets            Ticket[]
  devices            Device[]
  interactions       Interaction[]
  invoices           Invoice[]
  payments           Payment[]
  documents          Document[]
  portalAccount      ClientPortalAccount?
  marketingConsents  MarketingConsent[]
  campaignRecipients CampaignRecipient[] // ajouté pour la relation CampaignRecipient
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
  RESELLER
  VIP
}

model MarketingConsent {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  channel    Channel
  consented  Boolean  @default(false)
  updatedAt  DateTime @updatedAt

  @@unique([customerId, channel])
}

enum Channel {
  EMAIL
  SMS
  PUSH
}

model Interaction {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  type       String
  channel    String?
  content    String?
  agentId    String?
  agent      User?    @relation(fields: [agentId], references: [id])
  createdAt  DateTime @default(now())
}

// --- Portail Client ---
model ClientPortalAccount {
  id           String    @id @default(cuid())
  customerId   String    @unique
  customer     Customer  @relation(fields: [customerId], references: [id])
  username     String    @unique
  passwordHash String
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
}

// --- Catalogue d'offres ---
model Offer {
  id            String        @id @default(cuid())
  name          String
  description   String?
  category      OfferCategory
  price         Decimal
  currency      String        @default("XOF")
  dataLimitMb   Int?
  voiceLimitMin Int?
  smsLimit      Int?
  validFrom     DateTime
  validTo       DateTime?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  subscriptions Subscription[]
}

enum OfferCategory {
  PREPAID
  POSTPAID
  HYBRID
  DATA_ONLY
  ENTERPRISE
}

// --- Abonnements / Souscriptions ---
model Subscription {
  id           String       @id @default(cuid())
  customerId   String
  customer     Customer     @relation(fields: [customerId], references: [id])
  offerId      String
  offer        Offer        @relation(fields: [offerId], references: [id])
  msisdn       String       @unique
  imsi         String?      @unique
  iccid        String?      @unique
  status       SubStatus
  startDate    DateTime
  endDate      DateTime?
  billingCycle BillingCycle
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  invoices         Invoice[]
  provisioningLogs ProvisioningLog[]
}

enum SubStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
  PENDING_ACTIVATION
  PORT_IN_PROGRESS
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

// --- Numérotation & Portabilité ---
model PhoneNumberInventory {
  msisdn           String       @id
  status           NumberStatus
  reservedForSubId String?      @unique
  reservedAt       DateTime?
}

enum NumberStatus {
  AVAILABLE
  RESERVED
  ACTIVE
  QUARANTINE
  PORTED_OUT
}

// --- Facturation & Paiements ---
model Invoice {
  id             String        @id @default(cuid())
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  amount         Decimal
  tax            Decimal       @default(0)
  dueDate        DateTime
  paidAt         DateTime?
  status         InvoiceStatus
  pdfUrl         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  payments Payment[]
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id         String        @id @default(cuid())
  invoiceId  String
  invoice    Invoice       @relation(fields: [invoiceId], references: [id])
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  amount     Decimal
  method     PaymentMethod
  reference  String?
  status     PaymentStatus
  paidAt     DateTime      @default(now())
  createdAt  DateTime      @default(now())
}

enum PaymentMethod {
  MOBILE_MONEY
  BANK_TRANSFER
  CASH
  CREDIT_CARD
}

enum PaymentStatus {
  SUCCESS
  FAILED
  PENDING
}

// --- Tickets & Support ---
model Ticket {
  id            String         @id @default(cuid())
  customerId    String
  customer      Customer       @relation(fields: [customerId], references: [id])
  subject       String
  description   String?
  priority      Priority
  status        TicketStatus
  category      TicketCategory
  agentId       String?
  agent         User?          @relation("AgentTickets", fields: [agentId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  resolvedAt    DateTime?
  interventions Intervention[] // ajouté pour la relation Intervention.ticket
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketCategory {
  NETWORK_ISSUE
  BILLING
  ACTIVATION
  DEVICE_SUPPORT
  GENERAL_INQUIRY
}

// --- Interventions terrain ---
model Intervention {
  id           String             @id @default(cuid())
  ticketId     String
  ticket       Ticket             @relation(fields: [ticketId], references: [id])
  technicianId String?
  technician   User?              @relation(fields: [technicianId], references: [id])
  status       InterventionStatus
  scheduledAt  DateTime?
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime           @default(now())
}

enum InterventionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// --- Inventaire & Équipements ---
model Device {
  id           String       @id @default(cuid())
  serialNumber String       @unique
  imei         String?      @unique
  model        String
  brand        String?
  status       DeviceStatus
  customerId   String?
  customer     Customer?    @relation(fields: [customerId], references: [id])
  warehouseId  String?
  warehouse    Warehouse?   @relation(fields: [warehouseId], references: [id])
  warrantyEnd  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Warehouse {
  id      String   @id @default(cuid())
  name    String
  address String?
  devices Device[]
}

enum DeviceStatus {
  IN_STOCK
  ASSIGNED
  REPAIRING
  DECOMMISSIONED
}

// --- GED (Documents) ---
model Document {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  name       String
  url        String
  type       String
  uploadedAt DateTime @default(now())
}

// --- Campagnes Marketing ---
model Campaign {
  id           String         @id @default(cuid())
  name         String
  channel      Channel
  content      String
  targetFilter Json?
  status       CampaignStatus
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  campaignRecipients CampaignRecipient[]
}

model CampaignRecipient {
  id         String          @id @default(cuid())
  campaignId String
  campaign   Campaign        @relation(fields: [campaignId], references: [id])
  customerId String
  customer   Customer        @relation(fields: [customerId], references: [id])
  sentAt     DateTime?
  status     RecipientStatus
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
}

// --- Provisioning & Activation réseau ---
model ProvisioningLog {
  id             String             @id @default(cuid())
  subscriptionId String
  subscription   Subscription       @relation(fields: [subscriptionId], references: [id])
  action         String
  status         ProvisioningStatus
  request        Json?
  response       Json?
  createdAt      DateTime           @default(now())
}

enum ProvisioningStatus {
  SUCCESS
  FAILED
  PENDING
}
